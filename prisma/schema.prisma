generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                        String      @id
  first_name                String     
  last_name                 String   
  image_url                 String      
  email_addresses           String?
  username                 String?    
  created_at                Int
  updated_at                Int
  last_sign_in_at           Int
}

