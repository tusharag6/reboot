generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                        String      @id @default(uuid())
  externalId               String      @unique
  attributes                Json
  createdAt                 DateTime    @default(now())
  updatedAt                 DateTime    @updatedAt
}

