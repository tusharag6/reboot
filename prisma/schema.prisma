generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                        String      @id @default(uuid())
  externalId               String      @unique
  first_name                String     
  last_name                 String   
  image_url                 String      
  email_addresses           Json?
  username                 String?    
  created_at                DateTime
  updated_at                DateTime
}
